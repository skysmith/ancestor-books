  "app_root": "/Users/sky/Documents/codex/personal/projects/ancestor-books/image-gen",
  "packaging_goal": "Keep the cockpit local-first and shareable by treating models and local runtimes as dependencies instead of external API integrations.",
  "runtime": {
    "python": {
      "command": "python3",
      "notes": [
        "The dashboard backend is a local Python server launched from image-gen/dashboard.py.",
        "No Python package lockfile is required yet; this app currently relies on the standard library plus local Ollama."
      ]
    },
    "ollama": {
      "command": "ollama",
      "notes": [
        "Ollama must be installed locally and available either on PATH or at the standard macOS app binary path.",
        "Models are treated as required local dependencies for the dashboard."
      ]
    }
  },
  "models": {
    "generator": [
      {
        "role": "image_generation",
        "name": "x/z-image-turbo:latest",
        "required": true,
        "used_by": [
          "image-gen/dashboard.py",
          "scripts/generate_local_storyboard_images.py"
        ]
      }
    ],
    "review": [
      {
        "role": "local_review",
        "name": "llava:latest",
        "required": true,
        "preferred_short_name": "llava"
      },
      {
        "role": "local_review",
        "name": "qwen2.5vl:latest",
        "required": true,
        "preferred_short_name": "qwen2.5vl"
      }
    ],
    "prompt_fixer": [
      {
        "role": "prompt_rewrite",
        "name": "llama3.2:3b",
        "required": true
      }
    ]
  },
  "paths": {
    "must_exist": [
      "/Users/sky/Documents/codex/personal/projects/ancestor-books/image-gen/cockpit",
